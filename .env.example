# Configurações do Banco de Dados
DATABASE_URL="postgresql://username:password@localhost:5432/sensory_profile_db?schema=public"

# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Configurações de CORS
FRONTEND_URL=http://localhost:5173

# Configurações do Render
# DATABASE_URL será fornecido pelo Render quando você criar o serviço PostgreSQL

# Supabase Auth
SUPABASE_URL=https://xxxx.supabase.co

# AWS (Bedrock AI summaries + S3 document storage + SES reminder emails)
AWS_REGION=us-east-1
AWS_S3_BUCKET=sensory-profile-documents
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY only needed outside an IAM role
# (e.g. local dev) — the AWS SDK's default credential chain picks them up.

# Reminder email digest (POST /api/system/reminder-digest)
EMAIL_FROM_ADDRESS=lembretes@example.com
# Must be a verified SES sender identity in the target AWS account/region.
CRON_SECRET=replace-with-a-long-random-string
# Shared secret the external scheduler (Render Cron Job, etc.) sends as the
# X-Cron-Secret header. Not a user credential — never expose it to the frontend.

# Web Push (reminder digest push notifications, /api/notifications/push-subscriptions)
# Generate a pair once with `npx web-push generate-vapid-keys` and keep them
# stable — rotating them invalidates every subscription already stored.
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_SUBJECT=mailto:contato@example.com
